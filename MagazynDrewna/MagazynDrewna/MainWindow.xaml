<Window x:Class="MagazynDrewna.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MagazynDrewna"
        mc:Ignorable="d"
        Title="Magazyn Drewna" Height="450" Width="900">
    <Grid Margin="10">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <TextBlock Text="Magazyn Drewna"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="5"
                   Grid.ColumnSpan="3"/>

        <DataGrid x:Name="WoodGrid"
                  Grid.Row="1"
                  Grid.Column="0"
                  AutoGenerateColumns="False"
                  Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                <DataGridTextColumn Header="Gatunek" Binding="{Binding Gatunek}" Width="*"/>
                <DataGridTextColumn Header="Długość (m)" Binding="{Binding Dlugosc}" Width="100"/>
                <DataGridTextColumn Header="Ilość" Binding="{Binding Ilosc}" Width="80"/>
                <DataGridTextColumn Header="Lokalizacja" Binding="{Binding Lokalizacja}" Width="*"/>
                
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch"/>

        <StackPanel Grid.Row="1" Grid.Column="2" Margin="10">

            <TextBlock Text="Formularz" FontSize="18" Margin="0,0,0,10"/>

            <TextBlock Text="Nazwa"/>
            <TextBox x:Name="NazwaBox" Margin="0,0,0,10"/>

            <TextBlock Text="Gatunek"/>
            <ComboBox x:Name="GatunekBox" Margin="0,0,0,10">
                <ComboBoxItem Content="Iglaste"/>
                <ComboBoxItem Content="Liściaste"/>
            </ComboBox>

            <TextBlock Text="Długość (m)"/>
            <TextBox x:Name="DlugoscBox" Margin="0,0,0,10"/>

            <TextBlock Text="Ilość"/>
            <TextBox x:Name="IloscBox" Margin="0,0,0,10"/>

            <TextBlock Text="Lokalizacja"/>
            <TextBox x:Name="LokalizacjaBox" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">

                <Button Content="Dodaj"
                        Width="80"
                        Margin="5"/>

                <Button Content="Usuń"
                        Width="80"
                        Margin="5"/>
                
            </StackPanel>


        </StackPanel>

        
        
    </Grid>
</Window>
