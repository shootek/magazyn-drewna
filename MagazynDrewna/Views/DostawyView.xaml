<UserControl x:Class="MagazynDrewna.Views.DostawyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MagazynDrewna.Views"
             Focusable="True">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Historia dostaw" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Nowa dostawa"
                        Margin="15,0,0,0"
                        Padding="12,4"
                        Command="{x:Static local:DostawyView.NewDeliveryCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                <Button x:Name="TopEditButton"
                        Content="Edytuj"
                        Margin="8,0,0,0"
                        Padding="12,4"
                        Command="{x:Static local:DostawyView.EditDeliveryCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
            </StackPanel>

            <DataGrid x:Name="DeliveriesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="DeliveriesGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=dd.MM.yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95"/>
                    <DataGridTextColumn Header="Dostawca" Binding="{Binding Dostawca}" Width="*"/>
                    <DataGridTextColumn Header="Nr dokumentu" Binding="{Binding NumerDokumentu}" Width="110"/>
                    <DataGridTextColumn Header="Pozycje" Binding="{Binding LacznaIlosc}" Width="70"/>
                    <DataGridTextColumn Header="Szczegóły" Binding="{Binding OpisPozycji}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,0,0,0">
                <TextBlock x:Name="FormTitleText" Text="Szczegóły dostawy" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TextBlock Text="Data"/>
                <DatePicker x:Name="DataPicker"
                            Margin="0,2,0,8"
                            IsEnabled="False"
                            SelectedDateFormat="Short"
                            DisplayDateStart="2020-01-01"
                            DisplayDateEnd="2099-12-31"
                            SelectedDateChanged="DataPicker_SelectedDateChanged"/>

                <TextBlock x:Name="StatusInfoText"
                           Margin="0,0,0,8"
                           Foreground="#666"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Dostawca"/>
                <TextBox x:Name="DostawcaBox" Margin="0,2,0,8" IsEnabled="False"/>

                <TextBlock Text="Numer dokumentu"/>
                <TextBox x:Name="NumerDokumentuBox" Margin="0,2,0,8" IsEnabled="False"/>

                <TextBlock Text="Uwagi"/>
                <TextBox x:Name="UwagiBox" Margin="0,2,0,10" Height="60" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsEnabled="False"/>

                <TextBlock Text="Pozycje dostawy" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="180" Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                        <DataGridTextColumn Header="Gatunek" Binding="{Binding Gatunek}" Width="80"/>
                        <DataGridTextColumn Header="Dł. (m)" Binding="{Binding Dlugosc, StringFormat=N2}" Width="60"/>
                        <DataGridTextColumn Header="Ilość" Binding="{Binding Ilosc}" Width="50"/>
                        <DataGridTextColumn Header="Magazyn" Binding="{Binding Lokalizacja}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="PreviewActionsPanel" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="PreviewEditButton"
                            Content="Edytuj"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Command="{x:Static local:DostawyView.EditDeliveryCommand}"
                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                    <Button x:Name="CompleteDeliveryButton"
                            Content="Przyjmij do magazynu"
                            Padding="10,4"
                            Command="{x:Static local:DostawyView.CompleteDeliveryCommand}"
                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                </StackPanel>

                <StackPanel x:Name="EditPanel" Visibility="Collapsed">
                    <Border BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,10" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Dodaj pozycję" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="Nazwa"/>
                            <TextBox x:Name="ItemNazwaBox" Margin="0,2,0,6"/>
                            <TextBlock Text="Gatunek"/>
                            <ComboBox x:Name="ItemGatunekBox" Margin="0,2,0,6"/>
                            <TextBlock Text="Długość (m)"/>
                            <TextBox x:Name="ItemDlugoscBox" Margin="0,2,0,6"/>
                            <TextBlock Text="Ilość"/>
                            <TextBox x:Name="ItemIloscBox" Margin="0,2,0,6"/>
                            <TextBlock Text="Lokalizacja"/>
                            <ComboBox x:Name="ItemLokalizacjaBox" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Dodaj pozycję" Padding="8,4" Margin="0,0,8,0"
                                        Command="{x:Static local:DostawyView.AddItemCommand}"
                                        CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                                <Button Content="Usuń pozycję" Padding="8,4"
                                        Command="{x:Static local:DostawyView.RemoveItemCommand}"
                                        CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SaveDeliveryButton"
                                Content="Zatwierdź dostawę"
                                Padding="10,4"
                                Margin="0,0,8,0"
                                Command="{x:Static local:DostawyView.SaveDeliveryCommand}"
                                CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                        <Button Content="Anuluj"
                                Padding="10,4"
                                Command="{x:Static local:DostawyView.CancelDeliveryCommand}"
                                CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=local:DostawyView}}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
